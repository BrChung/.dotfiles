# Copy to config/zen-syncthing/env and fill in after Syncthing setup.
# install symlinks ~/.config/zen-syncthing/env → config/zen-syncthing/env (gitignored)
# Syncthing → Actions → Settings → General → API Key
SYNCTHING_API_KEY=""

# Syncthing → Folders → zen → Folder ID (e.g. abc12-def34)
SYNCTHING_FOLDER_ID=""

# Default Syncthing GUI/API URL
SYNCTHING_URL="http://127.0.0.1:8384"

# Zen profile directory — sync THIS folder only, not the whole zen/ tree.
# Find yours: Zen → about:profiles → Root Directory (folder name varies per install).
ZEN_PROFILE_DIR="$HOME/Library/Application Support/zen/Profiles/YOUR_PROFILE.Default (release)"

# Wait up to this many seconds for sync to finish after quitting Zen
SYNCTHING_WAIT_TIMEOUT=300
